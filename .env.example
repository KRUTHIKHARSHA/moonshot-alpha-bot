# =============================================================================
#   MoonshotAlpha Bot  —  Environment Configuration
# =============================================================================
#
#   HOW TO USE
#   ----------
#   1. Copy this file:   cp .env.example .env
#   2. Fill in every value marked  <REQUIRED>
#   3. Adjust optional values to match your setup
#   4. NEVER commit your real .env to Git
#      (it is already listed in .gitignore)
#
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  TELEGRAM
# ─────────────────────────────────────────────────────────────────────────────

# <REQUIRED>
# Your bot's HTTP API token.
# How to get it:
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot and follow the prompts
#   3. Copy the token that looks like:  123456789:ABCdef...
TELEGRAM_BOT_TOKEN=

# <REQUIRED>
# Your personal Telegram numeric user ID.
# This account receives admin notifications and has access to admin commands.
# How to find your ID:  search @userinfobot on Telegram and send /start
TELEGRAM_ADMIN_CHAT_ID=


# ─────────────────────────────────────────────────────────────────────────────
#  FIREBASE  (Firestore database)
# ─────────────────────────────────────────────────────────────────────────────
#
#  Firebase stores:  user subscriptions, alert history, wishlists, referrals
#
#  Setup steps:
#   1. Go to https://console.firebase.google.com
#   2. Create a project → Firestore Database → Start in production mode
#   3. Project Settings → Service Accounts → Generate new private key
#      (this downloads a JSON file, e.g. serviceAccountKey.json)
#   4. Base64-encode the file:
#
#        macOS / Linux:
#          base64 -i serviceAccountKey.json | tr -d '\n'
#
#        Windows PowerShell:
#          [Convert]::ToBase64String(
#            [IO.File]::ReadAllBytes("serviceAccountKey.json")
#          )
#
#   5. Paste the resulting string below (one line, no spaces or line breaks)
#
# <REQUIRED>
FIREBASE_CREDENTIALS_BASE64=


# ─────────────────────────────────────────────────────────────────────────────
#  SUPABASE  (relational database)
# ─────────────────────────────────────────────────────────────────────────────
#
#  Supabase stores:  wallet addresses, sniper trade logs, PnL records
#
#  Setup steps:
#   1. Go to https://supabase.com and create a new project
#   2. Project Settings → API → copy the values below
#
# <REQUIRED>
# Your project URL — looks like: https://xyzabc.supabase.co
SUPABASE_URL=

# <REQUIRED>
# Use the SERVICE ROLE key (not the anon key) — needed for server-side writes.
# Keep this secret — it bypasses row-level security.
SUPABASE_SERVICE_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  SOLANA RPC ENDPOINT
# ─────────────────────────────────────────────────────────────────────────────
#
#  Used by the Rug Interceptor for on-chain checks (mint authority,
#  freeze authority, holder concentration).
#
#  Free public endpoint — fine for development, rate-limited in production:
#    https://api.mainnet-beta.solana.com
#
#  Recommended paid providers for production (faster, no rate limits):
#    Helius    — https://rpc.helius.xyz/?api-key=YOUR_KEY
#                Sign up at https://helius.dev  (free tier available)
#    QuickNode — https://your-endpoint.solana-mainnet.quiknode.pro/YOUR_KEY/
#                Sign up at https://quicknode.com
#
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com


# ─────────────────────────────────────────────────────────────────────────────
#  TELEGRAM MINI APP  (WebApp frontend)
# ─────────────────────────────────────────────────────────────────────────────
#
#  The public HTTPS URL where your static/ frontend (index.html) is deployed.
#  This is opened when users tap the "Terminal" button inside the bot.
#
#  Free hosting options:
#    Vercel  — https://vercel.com   (recommended, deploy in 1 click)
#    Netlify — https://netlify.com
#    GitHub Pages — https://pages.github.com
#
#  Leave blank to disable Mini App buttons.
#
MINI_APP_URL=


# ─────────────────────────────────────────────────────────────────────────────
#  TRADING  —  Sniper defaults
# ─────────────────────────────────────────────────────────────────────────────

# SOL amount to spend per snipe.
# 0.1 = 0.1 SOL per trade
# Adjust based on your risk tolerance and wallet balance.
DEFAULT_BUY_AMOUNT_SOL=0.1

# Slippage tolerance in basis points.
# 100 bps = 1%  |  300 bps = 3%  |  500 bps = 5%
# Higher slippage = more likely to execute, but worse fill price.
# Recommended: 300 for normal conditions, 500 during high volatility.
DEFAULT_SLIPPAGE_BPS=300

# Jito bundle tip in lamports (1 SOL = 1,000,000,000 lamports).
# This is a bribe paid directly to the validator for priority landing.
#   100,000  = 0.0001 SOL  (default, works for normal conditions)
#   500,000  = 0.0005 SOL  (use during network congestion)
# 1,000,000  = 0.001 SOL   (use for time-critical sniping)
JITO_TIP_LAMPORTS=100000

# Maximum rug risk score allowed before the SAFE-mode sniper blocks a trade.
# Scale: 0 = perfectly clean, 100 = certain rug.
# Recommended range: 25–40
# Lower = stricter (fewer trades, more protection)
# Higher = more permissive (more trades, more risk)
MAX_RISK_SCORE=35

# Minimum USD liquidity a pool must have before the sniper fires.
# Pools below this threshold are too easy to drain (rug risk).
# Recommended: 10000 (i.e. $10,000)
MIN_LIQUIDITY_USD=10000


# ─────────────────────────────────────────────────────────────────────────────
#  TRADING  —  Ghost Manager (position monitor) defaults
# ─────────────────────────────────────────────────────────────────────────────

# Take-profit target as a percentage gain.
# 100  = sell when position is up 100% (2x)
# 200  = sell when position is up 200% (3x)
# 50   = sell when position is up 50%  (1.5x)
DEFAULT_TAKE_PROFIT_PCT=100

# Stop-loss limit as a percentage loss.
# 25 = auto-sell when position is down 25%
# 50 = auto-sell when position is down 50%
# Lower = tighter protection, more likely to be stopped out on dips.
DEFAULT_STOP_LOSS_PCT=25

# How often the Ghost Manager checks open position prices (in seconds).
# Lower = faster TP/SL response, but more API calls.
# Recommended: 10 (every 10 seconds)
POSITION_POLL_INTERVAL=10


# ─────────────────────────────────────────────────────────────────────────────
#  SCANNER  —  Token filter thresholds
# ─────────────────────────────────────────────────────────────────────────────

# Minimum USD liquidity for a token to appear in the scanner feed.
SCANNER_MIN_LIQUIDITY_USD=10000

# Minimum 1-hour trading volume in USD.
SCANNER_MIN_VOLUME_1H_USD=5000

# Minimum 5-minute price change percentage to qualify as a momentum signal.
# 3.0 = token must be up at least 3% in the last 5 minutes.
SCANNER_MIN_PRICE_CHANGE_5M=3.0


# ─────────────────────────────────────────────────────────────────────────────
#  WEB SERVER
# ─────────────────────────────────────────────────────────────────────────────

# Port for the Flask health-check endpoint (/  returns 200 OK).
# Hosting platforms like Render and Railway set PORT automatically.
# Leave as 8080 for local development.
PORT=8080
